@model IEnumerable<MVC_Project1294727.Models.Student>
@{
    ViewBag.Title = "Index";
}

<div class="row">
    <div class="col">
        <h2 class="display-4">Student List</h2>
        <div class="d-flex justify-content-end mb-2">
            <a class="btn btn-primary btn-sm" href="@Url.Action("Create","Students")">Add New Student</a>
        </div>
        <div>
            @foreach (var stnt in Model)
            {
                <div class="card mb-2">
                    <div class="card-header d-flex justify-content-between">
                        <div>
                            <img src="@stnt.Picture" width="32" height="32" style="border-radius:5px;" />
                            <label class="me-2"><b>Student :</b> @Html.DisplayFor(x => stnt.StudentName)</label>
                            <label class="me-2"><b>Date Of Birth :</b> @Html.DisplayFor(x => stnt.BirthDate)</label>
                            <label class="me-2"><b>Age :</b> @Html.DisplayFor(x => stnt.Age)</label>
                            <label class="me-2"><b>Marital Status :</b> @Html.DisplayFor(x => stnt.MaritalStatus)</label>
                        </div>
                        <div class="d-flex justify-content-end">
                            <a class="btn btn-success btn-sm me-1" href="@Url.Action("Edit", "Students", new {id=stnt.StudentID})">Edit</a>
                            <a class="btn btn-danger btn-sm" href="@Url.Action("Delete", "Students", new {id=stnt.StudentID})">Delete</a>
                        </div>
                    </div>
                    <div class="card-body">
                        <table class="table table-bordered table-striped table-sm">
                            <thead class="table-info">
                                <tr>
                                    <th>Course Id</th>
                                    <th>Title</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in stnt.Enrollments)
                                {
                                    <tr>
                                        <td>@Html.DisplayFor(x => item.Cours.CourseID)</td>
                                        <td>@Html.DisplayFor(x => item.Cours.Title)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>

</div>


