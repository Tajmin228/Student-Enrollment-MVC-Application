@model MVC_Project1294727.Models.ViewModels.StudentVM
@{
    ViewBag.Title = "Edit";
}

<div class="row">
    <div class="col">
        @using (Ajax.BeginForm(new AjaxOptions { HttpMethod = "POST", InsertionMode = InsertionMode.Replace, UpdateTargetId = "msg", OnComplete = "clearAll" }))
        {
            <div class="row">
                <div class="col-6">
                    <h2 class="display-5">Add New Student</h2>
                    @Html.HiddenFor(x=>x.StudentID)
                    @Html.HiddenFor(x=>x.Picture)
                    <div class="row mb-2">
                        @Html.LabelFor(x => x.StudentName, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-2" })
                        <div class="col-8">
                            @Html.TextBoxFor(x => x.StudentName, new { @class = "form-control form-control-sm" })
                        </div>
                        <div class="col-2">
                            @Html.ValidationMessageFor(x => x.StudentName, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="row mb-2">
                        @Html.LabelFor(x => x.BirthDate, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-2" })
                        <div class="col-8">
                            @Html.TextBoxFor(x => x.BirthDate,"{0:yyyy-MM-dd}", new { @class = "form-control form-control-sm", type = "date" })
                        </div>
                        <div class="col-2">
                            @Html.ValidationMessageFor(x => x.BirthDate, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="row mb-2">
                        @Html.LabelFor(x => x.Age, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-2" })
                        <div class="col-8">
                            @Html.TextBoxFor(x => x.Age, new { @class = "form-control form-control-sm" })
                        </div>
                        <div class="col-2">
                            @Html.ValidationMessageFor(x => x.Age, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="row mb-2">
                        @Html.LabelFor(x => x.PictureFile, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-2" })
                        <div class="col-8">
                            @Html.TextBoxFor(x => x.PictureFile, new { @class = "form-control form-control-sm", type = "file" })
                            <img src="@Model.Picture" width="32" height="32" style="border-radius:5px;" class="mt-2"/>
                        </div>
                        <div class="col-2">
                            @Html.ValidationMessageFor(x => x.PictureFile, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="row mb-2">
                        @Html.LabelFor(x => x.MaritalStatus, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-2" })
                        <div class="col-8">
                            @Html.CheckBoxFor(x => x.MaritalStatus)
                        </div>
                        <div class="col-2">
                            @Html.ValidationMessageFor(x => x.MaritalStatus, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="row mb-2">

                        <div class="col-10 offset-2">
                            <button type="submit" class="btn btn-primary">Update</button>
                        </div>
                    </div>
                </div>
                <div class="col-6">
                    <h2 class="display-5">Course List</h2>
                    <div class="d-flex justify-content-end">
                        <a class="btn btn-primary btn-sm mb-2" href="#" id="btnPlus"><i class="fa fa-plus"></i></a>
                    </div>
                    <div id="CourseContainer">
                        @foreach (var item in Model.CourseList)
                        {
                            @Html.Action("AddNewCourse", "Students", new{id=item })
                        }
                    </div>
                </div>
            </div>
            <div class="row mt-2">
                <div id="msg"></div>
            </div>
        }
    </div>
</div>

@section scripts{
    <script src="~/Scripts/jquery.unobtrusive-ajax.js"></script>
    <script>
        $("#form0").attr("enctype", "multipart/form-data");
        function clearAll() {
            $("#form0").trigger("reset");
        }
    </script>
}

